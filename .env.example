# ── NeuralPulse Environment Variables ──────────
# Copy this file to .env and fill in your keys

# Tavily Search API (required for news fetching)
TAVILY_API_KEY="tvly-your-key-here"

# Groq API (optional if users provide via frontend)
GROQ_API_KEY=""

# Google Gemini API (optional if users provide via frontend)
GOOGLE_API_KEY=""
